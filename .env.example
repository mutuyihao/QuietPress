# =============================================================================
# Supabase（必需）
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Vercel Supabase Marketplace 可能提供这个新版公开 key 名称：
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# =============================================================================
# Vercel 一键部署 bootstrap
# =============================================================================
# 仅 Vercel 一键部署 bootstrap 必需。初始密码是 QuietPress@2026!。
# 首次登录后请到 /admin/account 修改。
ADMIN_EMAIL=admin@example.com

# 可选。设为 1 会跳过构建期 Supabase migration/admin bootstrap。
# SKIP_SUPABASE_BOOTSTRAP=1

# =============================================================================
# 站点
# =============================================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# =============================================================================
# 存储 provider - 控制上传图片保存到哪里。
#
#   "supabase"（默认）- Supabase Storage
#   "s3"                  - AWS S3
#   "r2"                  - Cloudflare R2（S3 兼容）
#
# 留空会默认使用 supabase。后台存储页面可以在已配置 provider 之间切换；
# secret 仍然必须通过环境变量配置。
# =============================================================================
STORAGE_PROVIDER=supabase

# 可选。仅当后台存储页面没有手动配置配额时使用。
# Supabase Free Storage 配额当前按 1GB 展示，所以内置 fallback 是 1024。
# 如果你的 Supabase 套餐或组织配额不同，请设置这个值。
# DEFAULT_SUPABASE_STORAGE_QUOTA_MB=1024

# STORAGE_PROVIDER 为 "s3" 或 "r2" 时必需：
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_BUCKET=your-bucket-name
# S3_PUBLIC_URL_BASE=https://cdn.example.com

# 可选。默认 "auto"，适合 Cloudflare R2。
# AWS S3 请使用实际区域，例如 "us-east-1"。
# S3_REGION=auto

# =============================================================================
# Cron secret - 保护 /api/cron/* 端点的 bearer token
# =============================================================================
# CRON_SECRET=your-cron-secret
