# =============================================================================
# Supabase（必填）
# =============================================================================
# 必填。Supabase 项目 URL，浏览器和服务端都会使用。
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# 必填（二选一）。浏览器公开 key。
# 旧项目通常使用 NEXT_PUBLIC_SUPABASE_ANON_KEY；Vercel Supabase Marketplace
# 可能注入 NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY。
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# 条件必填（二选一）。服务端管理员能力、AI/MCP OAuth、DCR、审计、Vercel bootstrap
# 需要 service-role/secret key。Vercel Marketplace 可能注入 SUPABASE_SECRET_KEY。
# 不要把这个值暴露到浏览器或写成 NEXT_PUBLIC_*。
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_SECRET_KEY=your-supabase-secret-key

# 可选。部分平台会提供服务端 Supabase URL；bootstrap 会优先使用它，
# 没有时使用 NEXT_PUBLIC_SUPABASE_URL。
# SUPABASE_URL=https://your-project.supabase.co

# =============================================================================
# Vercel 一键部署 bootstrap（仅 Vercel 构建期需要）
# =============================================================================
# 条件必填。VERCEL=1 且未设置 SKIP_SUPABASE_BOOTSTRAP=1 时必填。
# Vercel Supabase Marketplace 通常会自动注入，用于执行数据库迁移。
# POSTGRES_URL_NON_POOLING=postgresql://postgres:password@host:5432/postgres

# 条件必填。VERCEL=1 且未设置 SKIP_SUPABASE_BOOTSTRAP=1 时必填。
# bootstrap 会用它创建第一个管理员账号。初始密码是 QuietPress@2026!。
# 首次登录后请到 /admin/account 修改。
ADMIN_EMAIL=admin@example.com

# 可选。设为 1 会跳过构建期 Supabase migration/admin bootstrap。
# 仅用于排障或你已经手动执行迁移和管理员初始化的场景；新项目首次部署不要开启。
# SKIP_SUPABASE_BOOTSTRAP=1

# =============================================================================
# 站点 URL
# =============================================================================
# 生产环境建议必填。用于 RSS、Sitemap、JSON-LD、canonical URL、OAuth resource 等绝对地址。
# 本地开发可以使用 http://localhost:3000。
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# =============================================================================
# 存储 provider
# =============================================================================
# 可选。控制上传图片保存到哪里；留空默认 supabase。
#
#   "supabase" - Supabase Storage
#   "s3"       - AWS S3 或其它 S3 兼容服务
#   "r2"       - Cloudflare R2（S3 兼容）
#
# 后台存储页面可以在已配置 provider 之间切换；secret 仍然必须通过环境变量配置。
STORAGE_PROVIDER=supabase

# 可选。仅当后台存储页面没有手动配置配额时使用。
# Supabase Free Storage 配额当前按 1GB 展示，所以内置 fallback 是 1024。
# 如果你的 Supabase 套餐或组织配额不同，请设置这个值。
# DEFAULT_SUPABASE_STORAGE_QUOTA_MB=1024

# 条件必填。STORAGE_PROVIDER 为 "s3" 或 "r2"，或后台选择 S3/R2 provider 时必填。
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_BUCKET=your-bucket-name
# S3_PUBLIC_URL_BASE=https://cdn.example.com

# 可选。默认 "auto"，适合 Cloudflare R2。
# AWS S3 请使用实际区域，例如 "us-east-1"。
# S3_REGION=auto

# =============================================================================
# Cron secret
# =============================================================================
# 条件必填。只有启用计划发布并调用 /api/cron/publish-scheduled 时才需要。
# 请求必须携带：Authorization: Bearer <CRON_SECRET>
# CRON_SECRET=your-cron-secret
