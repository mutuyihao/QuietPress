# =============================================================================
# Supabase (required)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# =============================================================================
# Site
# =============================================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# =============================================================================
# Storage provider — controls where uploaded images are stored.
#
#   "supabase" (default) — Supabase Storage
#   "s3"                  — AWS S3
#   "r2"                  — Cloudflare R2 (S3-compatible)
#
# Leave unset to default to supabase. The admin Storage page can switch between
# configured providers at runtime; secrets still belong in environment variables.
# =============================================================================
STORAGE_PROVIDER=supabase

# Optional. Used only when the admin Storage page has no manual quota.
# Supabase Free Storage quota is currently 1GB, so the built-in fallback is 1024.
# Set this when your Supabase plan or organization quota is different.
# DEFAULT_SUPABASE_STORAGE_QUOTA_MB=1024

# Required when STORAGE_PROVIDER is "s3" or "r2":
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_BUCKET=your-bucket-name
# S3_PUBLIC_URL_BASE=https://cdn.example.com

# Optional. Defaults to "auto", which is suitable for Cloudflare R2.
# Use an AWS region such as "us-east-1" for AWS S3.
# S3_REGION=auto

# =============================================================================
# Cron secret — bearer token protecting /api/cron/* endpoints
# =============================================================================
# CRON_SECRET=your-cron-secret
